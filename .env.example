# API Keys
AEMET_API_KEY=your_aemet_api_key_here
METEOGALICIA_API_KEY=your_meteogalicia_api_key_here
MAPBOX_TOKEN=your_mapbox_token_here

# Database
POSTGRES_USER=prepai
POSTGRES_PASSWORD=prepai_secure_password
POSTGRES_DB=prepai_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://prepai:prepai_secure_password@db:5432/prepai_db

# Redis
REDIS_URL=redis://redis:6379/0

# App
SECRET_KEY=change_me_to_a_random_secret_key_32chars
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# ML
MODEL_PATH=/app/data/models
DATA_PATH=/app/data

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
