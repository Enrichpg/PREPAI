# ─────────────────────────────────────────────
# PREPAI — Environment Configuration Example
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Active External APIs
# 1. AEMET OpenData (key required — register free at https://opendata.aemet.es)
AEMET_API_KEY=your_aemet_api_key_here
# 2. OSM Overpass — public, no key needed
# 3. Open-Elevation — public, no key needed

# Database
POSTGRES_USER=prepai
POSTGRES_PASSWORD=prepai_secure_password
POSTGRES_DB=prepai_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://prepai:prepai_secure_password@localhost:5432/prepai_db

# Redis
REDIS_URL=redis://localhost:6379/0

# App
SECRET_KEY=change_me_to_a_random_secret_key_32chars
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# ML
MODEL_PATH=./data/models
DATA_PATH=./data

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
